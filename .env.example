# TrajectoryCache environment configuration
# Copy this file to .env and fill in your values

# API server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# RSU hardware (for production deployment)
RSU_POSITION_X=2500.0
RSU_POSITION_Y=0.0
RSU_COVERAGE_RADIUS_M=300.0
RSU_CS_CAPACITY_MB=500.0

# Algorithm parameters (overrides config file if set)
TC_LAMBDA=0.75
TC_ALPHA=0.5
TC_ETA_HW=0.90
TC_ETA_LW=0.70
TC_R_GRZ=300.0

# Simulation
SIM_SEED=42
SIM_DURATION=600

# Monitoring
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# SUMO co-simulation (optional)
SUMO_HOME=/usr/share/sumo
SUMO_BINARY=sumo
TRACI_PORT=8813

# NS-3 / ndnSIM (optional)
NS3_DIR=/opt/ns-3.36
NDNSIM_BUILD=/opt/ns-3.36/build
